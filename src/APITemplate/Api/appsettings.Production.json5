/**
 * ──────────────────────────────────────────────────────────────────────────────
 * PRODUCTION OVERRIDES (JSON5)
 * ──────────────────────────────────────────────────────────────────────────────
 * These settings are active only when ASPNETCORE_ENVIRONMENT is 'Production'.
 * Ensure all sensitive values are injected via Kubernetes Secrets or Env Vars.
 */
{
  "App": {
    "ServiceName": "APITemplate"
  },
  "SystemIdentity": {
    "DefaultActorId": "00000000-0000-0000-0000-000000000000"
  },
  "BootstrapTenant": {
    "Code": "default",
    "Name": "Default Tenant"
  },
  
  // Enforce getting HMAC key from environment in production
  "Redaction": {
    "HmacKeyEnvironmentVariable": "APITEMPLATE_REDACTION_HMAC_KEY",
    "KeyId": 1001
  },
  
  // Production observability endpoints (e.g. Alloy/Grafana Agent)
  "Observability": {
    "Otlp": {
      "Endpoint": "http://alloy:4317"
    },
    "Aspire": {
      "Endpoint": ""
    },
    "Exporters": {
      "Aspire": {
        "Enabled": false
      },
      "Otlp": {
        "Enabled": true
      },
      "Console": {
        "Enabled": false
      }
    }
  },
  
  // Production structured JSON logging and log rotation
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File",
      "Serilog.Expressions",
      "Serilog.Formatting.Compact",
      "Serilog.Enrichers.Environment",
      "Serilog.Enrichers.Thread"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId"
    ],
    "Properties": {
      "Application": "APITemplate"
    },
    "Filter": [
      {
        "Name": "ByExcluding",
        "Args": {
          "expression": "RequestPath like '/health%'"
        }
      }
    ],
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "formatter": "Serilog.Formatting.Compact.RenderedCompactJsonFormatter, Serilog.Formatting.Compact"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/apitemplate-.log",
          "formatter": "Serilog.Formatting.Compact.RenderedCompactJsonFormatter, Serilog.Formatting.Compact",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7,
          "fileSizeLimitBytes": 1048576,
          "rollOnFileSizeLimit": true,
          "shared": true
        }
      }
    ]
  },
  "RateLimiting": {
    "AllowDistributedRateLimiting": true
  },
  "Request": {
    "RequestSizeLimitMb": 1
  },
  // Strict HTTPs enforcement for production
  "Hsts": {
    "Preload": true,
    "IncludeSubDomains": true,
    "MaxAgeDays": 365
  }
}
